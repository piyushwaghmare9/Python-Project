    const isChecked = answerChecked[currentQuestionIndex];
    const isCorrect = answerResult[currentQuestionIndex];
    const bookmarked = isBookmarked(currentSubject.name, currentChapter, q.id);
    let html = `<div class="breadcrumb"><a onclick="renderSubjects()">Subjects</a> › <a onclick="renderChapters()">${currentSubject.name}</a> › <span>${currentChapter}</span></div>
      <button class="back-btn" onclick="renderChapters()">← Back to Chapters</button>
      <div class="question-container"><div class="progress-wrapper"><div class="progress-header"><span class="progress-label">Progress</span><span class="progress-count">Q${currentQuestionIndex+1}/${total}</span></div>
      <div class="progress-bar-bg"><div class="progress-fill" style="width:${progressPercent}%"></div></div></div>
      <div class="question-card"><div class="question-header"><div class="question-badge"><span class="question-number">Q${currentQuestionIndex+1}</span><span class="exam-tag">${q.exam}</span></div></div>
      <div class="question-text">${q.text}</div><div class="options">`;
    q.options.forEach((opt, idx) => {
      const letter = String.fromCharCode(65+idx);
      const isSelected = (selected === idx);
      let addClass = (isChecked && isSelected) ? (isCorrect ? 'correct-highlight' : 'wrong-highlight') : '';
      html += `<label class="option ${addClass}"><input type="radio" name="question" value="${idx}" ${isSelected ? 'checked' : ''} onchange="selectOption(${idx})"><span><strong>${letter}.</strong> ${opt}</span></label>`;
    });
    html += `</div><div class="action-buttons"><button class="btn btn-check" id="checkBtn">✅ Check</button><button class="btn btn-bookmark ${bookmarked ? 'bookmarked' : ''}" id="bookmarkBtn">${bookmarked ? '★ Bookmarked' : '☆ Bookmark'}</button></div>
      <div id="fbMsg" class="feedback-message"></div><div class="question-nav"><button class="btn btn-secondary" onclick="prevQ()" ${currentQuestionIndex===0 ? 'disabled' : ''}>← Prev</button>
      <div class="nav-buttons"><button class="btn btn-primary" onclick="nextQ()">Next →</button></div></div>
      <div class="question-dots-section"><div class="dots-grid" id="dotsGrid"></div><div class="legend"><span><i class="legend-dot" style="background:linear-gradient(135deg,#1e1b4b,#4c1d95);"></i> Current</span>
      <span><i class="legend-dot" style="background:#10b981;"></i> Correct</span><span><i class="legend-dot" style="background:#ef4444;"></i> Wrong</span>
      <span><i class="legend-dot" style="background:#3b82f6;"></i> Attempted</span><span><i class="legend-dot" style="background:var(--chip-bg);"></i> Unseen</span></div></div></div></div>`;
    mainContent.innerHTML = html;
    const grid = document.getElementById('dotsGrid');
    if(grid) for(let i=0;i<total;i++){ let cls='q-dot'; if(i===currentQuestionIndex) cls+=' current'; else if(answerChecked[i]) cls+= answerResult[i] ? ' checked-correct' : ' checked-wrong'; else if(userAnswers[i]!==undefined) cls+=' answered'; else cls+=' unanswered'; grid.innerHTML += `<button class="${cls}" onclick="jumpToQ(${i})">${i+1}</button>`; }
    document.getElementById('checkBtn')?.addEventListener('click',()=>checkAnswer());
    document.getElementById('bookmarkBtn')?.addEventListener('click',()=>toggleBookmark());
  }

  window.selectOption = function(idx){ userAnswers[currentQuestionIndex]=idx; answerChecked[currentQuestionIndex]=false; answerResult[currentQuestionIndex]=undefined; renderSingleQuestion(); };
  window.checkAnswer = function(){ let s=userAnswers[currentQuestionIndex]; if(s===undefined){ alert("Select an option"); return; } let q=currentQuestions[currentQuestionIndex]; let correct=(s===q.correct); answerChecked[currentQuestionIndex]=true; answerResult[currentQuestionIndex]=correct; let fb=document.getElementById('fbMsg'); fb.style.display='block'; fb.className=`feedback-message ${correct?'feedback-correct':'feedback-wrong'}`; fb.innerHTML=correct?'✅ Correct!':`❌ Incorrect. Correct: ${String.fromCharCode(65+q.correct)}. ${q.options[q.correct]}`; renderSingleQuestion(); };
  window.toggleBookmark = function(){ let q=currentQuestions[currentQuestionIndex]; if(isBookmarked(currentSubject.name,currentChapter,q.id)) removeBookmark(currentSubject.name,currentChapter,q.id); else addBookmark(currentSubject.name,currentChapter,q.id,q.text,currentQuestionIndex); renderSingleQuestion(); };
  window.prevQ = function(){ if(currentQuestionIndex>0){ currentQuestionIndex--; renderSingleQuestion(); } };
  window.nextQ = function(){ if(currentQuestionIndex<currentQuestions.length-1){ currentQuestionIndex++; renderSingleQuestion(); } else { let correct=0; for(let i=0;i<currentQuestions.length;i++) if(answerChecked[i] && answerResult[i]) correct++; showResult(correct); } };
  window.jumpToQ = function(i){ currentQuestionIndex=i; renderSingleQuestion(); };
  function showResult(correct){ mainContent.innerHTML=`<div class="result-card"><div class="result-icon">🏆</div><h2>Chapter Completed!</h2><div class="score">${correct}/${currentQuestions.length}</div><p>${Math.round((correct/currentQuestions.length)*100)}%</p><div class="result-actions"><button class="btn btn-primary" onclick="renderSubjects()">🏠 Home</button><button class="btn btn-secondary" onclick="renderChapters()">📖 Back</button><button class="btn btn-secondary" onclick="location.reload()">🔄 Retake</button></div></div>`; }
  
  function renderBookmarksPage() {
    if(bookmarks.length===0){ mainContent.innerHTML=`<div class="empty-bookmarks"><div style="font-size:64px">🔖</div><h3>No Bookmarks</h3><button class="btn btn-primary" onclick="renderSubjects()">Browse Subjects</button></div>`; return; }
    let grouped={}; bookmarks.forEach(b=>{ if(!grouped[b.subjectName]) grouped[b.subjectName]={}; if(!grouped[b.subjectName][b.chapterName]) grouped[b.subjectName][b.chapterName]=[]; grouped[b.subjectName][b.chapterName].push(b); });
    let html=`<div class="top-bar"><div class="page-title"><h1>🔖 Bookmarks</h1></div></div><div class="bookmarks-container">`;
    for(let sub in grouped){ html+=`<div class="bookmark-group"><div class="bookmark-group-header" onclick="this.nextElementSibling.style.display=this.nextElementSibling.style.display==='none'?'block':'none'"><h3>📘 ${sub}</h3><span>▼</span></div><div class="bookmark-chapter-list">`;
      for(let chap in grouped[sub]){ html+=`<div class="bookmark-chapter-item"><div class="bookmark-chapter-title" onclick="let el=document.getElementById('bmc-${sub.replace(/\s/g,'')}-${chap.replace(/\s/g,'')}'); if(el) el.style.display=el.style.display==='none'?'block':'none'"><span>📖</span> ${chap} (${grouped[sub][chap].length})<span style="margin-left:auto;">▼</span></div><div id="bmc-${sub.replace(/\s/g,'')}-${chap.replace(/\s/g,'')}" class="bookmark-questions-list" style="display:none">`;
        grouped[sub][chap].forEach(b=>{ html+=`<div class="bookmark-question-item" onclick="navigateToBookmark('${sub}','${chap}',${b.questionId},${b.questionIndex})"><div style="flex:1"><span class="bookmark-question-id">Q${b.questionId}</span> ${b.questionText.substring(0,70)}...</div><button class="remove-bookmark" onclick="event.stopPropagation(); removeBookmarkAndRefresh('${sub}','${chap}',${b.questionId})">🗑️</button></div>`; });
        html+=`</div></div>`; }
      html+=`</div></div>`; }
    html+=`</div>`; mainContent.innerHTML=html;
  }
  window.navigateToBookmark = function(sub,chap,qid,idx){ currentSubject=subjectsData.find(s=>s.name===sub); if(currentSubject){ currentChapter=chap; if(sub==="Linear Algebra & Univariate Calculus" && chap==="Unit 1: Matrices & Linear Algebra") currentQuestions=[...matricesQuestions]; else if(sub==="Engineering Chemistry" && chap==="Unit 1: Water Technology") currentQuestions=[...waterTechQuestions]; else if(sub==="Engineering Chemistry" && chap==="Unit 2: Fuels and Combustion") currentQuestions=[...fuelsQuestions]; else{ currentQuestions=[]; for(let i=1;i<=100;i++) currentQuestions.push({id:i,text:`${chap} - Q${i}`,options:[`A${i}`,`B${i}`,`C${i}`,`D${i}`],correct:Math.floor(Math.random()*4),exam:"Practice"}); } let found=currentQuestions.findIndex(q=>q.id===qid); currentQuestionIndex=found!==-1?found:idx; userAnswers={}; answerChecked={}; answerResult={}; renderSingleQuestion(); } };
  window.removeBookmarkAndRefresh = function(sub,chap,qid){ removeBookmark(sub,chap,qid); renderBookmarksPage(); };

  document.querySelectorAll('[data-view]').forEach(el=>{ el.addEventListener('click',()=>{ document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active')); el.classList.add('active'); if(el.dataset.view==='subjects') renderSubjects(); else if(el.dataset.view==='bookmarks') renderBookmarksPage(); else mainContent.innerHTML='<div style="padding:40px;text-align:center">📊 Performance analytics coming soon!</div>'; }); });
  document.getElementById('themeToggle').addEventListener('click', toggleTheme);
  initTheme();
  window.renderSubjects = renderSubjects;
</script>
</body>
</html>
